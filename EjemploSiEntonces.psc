//Problema:Determinar si un numero
//ingresado por el usuario es + o -
Algoritmo EjemploSiEntonces
	//Entradas
	Definir num Como Entero
	Escribir "Dame un numero entero cualquiera: "
	leer num
	//Proceso 
	si (num>0) Entonces
		Escribir "Soy un numero POSITIVO"
	sino
		Escribir "Soy un numero NEGATIVO"	
	FinSi
	//Salidas
FinAlgoritmo
